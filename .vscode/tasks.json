{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "nodemon",
			"path": "backend/",
			"group": "build",
			"isBackground": true,
			"problemMatcher": [
				{
					"pattern": [
						{
							"regexp": ".",
							"file": 1,
							"location": 2,
							"message": 3
						}
					],
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".",
						"endsPattern": "."
					}
				}
			],
			"label": "start server"
		},
		{
			"type": "npm",
			"script": "start",
			"path": "frontend/chronicle-suite/",
			"group": "build",
			"label": "start react app",
			"dependsOn": "start server",
			"detail": "react-scripts start",
			"isBackground": true,
			"problemMatcher": [
				{
					"pattern": [
						{
							"regexp": ".",
							"file": 1,
							"location": 2,
							"message": 3
						}
					],
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".",
						"endsPattern": "."
					}
				}
			],
		}
	]
}